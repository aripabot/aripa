{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["src/*"],
      "@aripabot/core/*": ["../../packages/core/src/*"]
    },
    "plugins": [{ "name": "next" }],
    "types": ["bun"]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "next.config.ts"
  ]
}
