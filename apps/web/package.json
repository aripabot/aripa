{
  "name": "@aripabot/web",
  "version": "0.1.1-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run server:dev & bunx vite --host 127.0.0.1",
    "server:dev": "WEB_API_PORT=4174 bun --watch src/server/index.ts",
    "build": "bunx vite build",
    "start": "WEB_STATIC_DIR=dist bun src/server/index.ts",
    "preview": "bun run build && bun run start",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun --bun ../../node_modules/vitest/vitest.mjs run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aripabot/core": "workspace:*",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
