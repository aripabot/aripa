{
  "name": "@aripabot/bot",
  "version": "0.3.0-alpha.1",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "exports": {
    "./*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "logs:ui:dev": "bun run dev | pinorama --open",
    "logs:ui": "bun run start | pinorama --open",
    "onboard": "bun --env-file=../../.env src/onboarding.ts",
    "update": "bun --env-file=../../.env src/update.ts",
    "start": "bun --env-file=../../.env src/index.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun --bun ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "bun --bun ../../node_modules/vitest/vitest.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aripabot/core": "workspace:*",
    "@opentui/core": "^0.2.2",
    "discord.js": "^14.26.3"
  }
}
