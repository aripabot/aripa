{
  "name": "@aripabot/bot",
  "version": "0.1.1-alpha.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "exports": {
    "./*": {
      "types": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "logs:ui:dev": "bun run dev | pinorama --open",
    "logs:ui": "bun run start | pinorama --open",
    "onboard": "bun --env-file=../../.env src/onboarding.ts",
    "update": "bun --env-file=../../.env src/update.ts",
    "start": "bun --env-file=../../.env src/index.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun --bun ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "bun --bun ../../node_modules/vitest/vitest.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.109",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@ai-sdk/provider": "^3.0.10",
    "@aripabot/core": "workspace:*",
    "@loglayer/transport-pino": "^3.0.2",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opentui/core": "^0.2.2",
    "ai": "^6.0.168",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.3",
    "loglayer": "^9.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}