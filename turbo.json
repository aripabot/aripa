{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "public/**",
        "next.config.*",
        "postcss.config.*",
        "tsconfig.json",
        "package.json",
        "!**/.DS_Store"
      ],
      "outputs": []
    },
    "@aripabot/web#build": {
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "lint": {
      "inputs": ["src/**", "tests/**", "tsconfig.json", "package.json", "!**/.DS_Store"]
    },
    "format": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**", "tests/**", "tsconfig.json", "package.json", "!**/.DS_Store"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**", "tests/**", "tsconfig.json", "package.json", "!**/.DS_Store"]
    }
  }
}
