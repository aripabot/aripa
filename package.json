{
  "name": "aripa",
  "version": "0.0.1-alpha.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "logs:ui:dev": "bun run dev | pinorama --open",
    "logs:ui": "bun run start | pinorama --open",
    "onboard": "bun src/onboarding.ts",
    "update": "bun src/update.ts",
    "start": "bun src/index.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "test": "bun --bun node_modules/vitest/vitest.mjs run",
    "test:watch": "bun --bun node_modules/vitest/vitest.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.109",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@ai-sdk/provider": "^3.0.10",
    "@loglayer/transport-pino": "^3.0.2",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opentui/core": "^0.2.2",
    "ai": "^6.0.168",
    "discord-api-types": "^0.38.47",
    "discord.js": "^14.26.3",
    "loglayer": "^9.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "4.1.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "pinorama-studio": "^0.5.2",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "hono": "^4.12.19",
    "ip-address": "^10.2.0"
  }
}